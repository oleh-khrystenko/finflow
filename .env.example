# ============================================================
# LucidShip Environment Configuration
# 
# FAIL FAST POLICY:
# All variables below are required unless marked as defaults below.
# The app should crash on missing required vars.
# Do not add silent fallbacks in code.
#
# Defaults in code:
#   NODE_ENV (development), PORT (4000),
#   WEB_URL (http://localhost:3000)
# ============================================================

# Block order is intentional:
# 1) Runtime / Orchestration -> 2) Backend (API) -> 3) Frontend (Web)

# ============================================================
# 1) Runtime / Orchestration
# ============================================================
NODE_ENV=development

# External ports (used by Docker Compose)
WEB_PORT=3000
# API app reads PORT internally; API_PORT is mapped to PORT by compose
API_PORT=4000

# ============================================================
# 2) Backend (apps/api)
# ============================================================

# API -> Web URL (OAuth redirects, magic-link URL, CORS allowlist)
WEB_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<app>

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=<generate-random-32-byte-hex>
JWT_REFRESH_SECRET=<generate-random-32-byte-hex>

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
# Callback goes through web reverse proxy so cookie lands on the web domain
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key
# Optional in development (production should set verified sender)
# RESEND_FROM_EMAIL=LucidShip <onboarding@resend.dev>

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_MONTHLY_USD=price_your_stripe_price_id
# Stripe — Credit Pack Prices (one-off payments)
# Create as one-time payment prices (not recurring) in Stripe Dashboard
STRIPE_PRICE_CREDITS_5_USD=price_xxx
STRIPE_PRICE_CREDITS_10_USD=price_xxx
STRIPE_PRICE_CREDITS_20_USD=price_xxx
# Optional (defaults to WEB_URL/billing/success and WEB_URL/billing/cancel)
# BILLING_SUCCESS_URL=http://localhost:3000/billing/success
# BILLING_CANCEL_URL=http://localhost:3000/billing/cancel

# Payment type toggles (optional, default: true)
# Set to 'false' to disable a specific payment type
PAYMENTS_SUBSCRIPTION_ENABLED=true
PAYMENTS_ONE_OFF_ENABLED=true

# ============================================================
# 3) Frontend (apps/web)
# ============================================================

# Internal API URL for Next.js reverse proxy (server-side only, NOT NEXT_PUBLIC_)
# Next.js rewrites /api/* to this destination. Default: http://localhost:4000
# Docker: http://api:4000 | Prod: internal API service URL
API_INTERNAL_URL=http://localhost:4000

# Public site URL (SEO canonical/Open Graph)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public API base URL used in browser (relative — goes through Next.js reverse proxy)
NEXT_PUBLIC_API_URL=/api

# Frontend payment type toggles (sync with backend PAYMENTS_*_ENABLED)
NEXT_PUBLIC_PAYMENTS_SUBSCRIPTION_ENABLED=true
NEXT_PUBLIC_PAYMENTS_ONE_OFF_ENABLED=true
