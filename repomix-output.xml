                expect(mockUserModel.findOneAndUpdate).toHaveBeenCalled();
                expect(mockWebhookEventModel.updateOne).toHaveBeenCalledWith(
                    { provider: 'stripe', providerEventId: 'evt_ooo' },
                    { $set: { status: 'applied' } },
                    { maxTimeMS: 10000 }
                );
            });
        });

